{
  "name": "boomboom-ai-chat",
  "version": "1.0.0",
  "description": "Minimalist AI Chat with OpenRouter and Bun",
  "main": "backend.ts",
  "type": "module",
  "scripts": {
    "start": "bun run backend.ts",
    "build": "bun build ./app.ts --outdir ./dist",
    "dev": "bun build ./app.ts --outdir ./dist --watch"
  },
  "dependencies": {
    "@openrouter/sdk": "^1.0.0"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
